---
import Base from '../layouts/Base.astro';

const tools = [
  // ===== 图片处理 =====
  { name: '图片压缩', icon: '🗜️', url: 'https://www.kuaisutupo.xyz/', cat: 'image', desc: '无损压缩图片体积' },
  { name: '批量编辑', icon: '✂️', url: 'https://imgedit.hpennn.xyz/', cat: 'image', desc: '批量裁剪/旋转/水印' },
  { name: '尺寸修改', icon: '📐', url: 'https://imgsize.hpennn.xyz/', cat: 'image', desc: '调整图片尺寸像素' },
  { name: 'OCR识别', icon: '🔍', url: 'https://ocr.hpennn.xyz/', cat: 'image', desc: '图片文字识别导出' },

  // ===== 文字处理 =====
  { name: '文字工具', icon: '📝', url: 'https://www.hpenn.xyz/', cat: 'text', desc: '字数统计/格式转换' },

  // ===== 文档处理 =====
  { name: '文档转换', icon: '📄', url: 'https://convert.hpennn.xyz/', cat: 'doc', desc: 'PDF/Word/图片互转' },
  { name: '表格生成', icon: '📊', url: 'https://table.hpennn.xyz/', cat: 'doc', desc: '快速生成Excel表格' },
  { name: '文档总结', icon: '📋', url: 'https://doc.hpenn.xyz/', cat: 'doc', desc: 'AI一键提取要点' },

  // ===== AI 工具 =====
  { name: 'AI文案', icon: '✨', url: 'https://www.zhinenti.xyz/', cat: 'ai', desc: 'AI智能文案生成' },
  { name: 'AI智能命名', icon: '🏷️', url: 'https://www.hpenn.online/', cat: 'ai', desc: '取名/品牌/项目命名' },
  { name: 'AI祝福语', icon: '💝', url: 'https://www.zhinenti.vip/', cat: 'ai', desc: '节日祝福/生日贺词' },
  { name: 'AI简历', icon: '📑', url: 'https://resume.hpenn.xyz/', cat: 'ai', desc: '一键生成专业简历' },
  { name: 'AI PPT', icon: '📊', url: 'https://ppt.hpennn.xyz/', cat: 'ai', desc: 'AI生成演示文稿' },
  { name: '智能营销', icon: '📣', url: 'https://market.hpennn.xyz/', cat: 'ai', desc: 'AI营销文案生成' },
  { name: '内容工具', icon: '💡', url: 'https://content.hpennn.xyz/', cat: 'ai', desc: 'AI内容创作助手' },
  { name: 'AI客服', icon: '🤖', url: 'https://www.zhinenti.cn/', cat: 'ai', desc: 'AI智能对话客服' },

  // ===== 开发工具 =====
  { name: '开发工具', icon: '⚙️', url: 'https://www.hpennn.xyz/', cat: 'dev', desc: '开发者效率工具' },
  { name: '快工具', icon: '🚀', url: 'https://www.kuaisu.online/', cat: 'dev', desc: '实用在线小工具' },
  { name: 'AI导航', icon: '🧭', url: 'https://www.hpennn.online/', cat: 'dev', desc: 'AI工具资源导航' },

  // ===== 推广营销 =====
  { name: '发布助手', icon: '📤', url: 'https://publish.hpennn.xyz/', cat: 'market', desc: '多平台一键发布' },
];

const categories = [
  { id: 'all', name: '全部', emoji: '🏠' },
  { id: 'image', name: '图片', emoji: '🖼️' },
  { id: 'text', name: '文字', emoji: '✍️' },
  { id: 'doc', name: '文档', emoji: '📁' },
  { id: 'ai', name: 'AI', emoji: '🤖' },
  { id: 'dev', name: '开发', emoji: '💻' },
  { id: 'market', name: '推广', emoji: '📢' },
];
---

<Base>
  <!-- ===== Header ===== -->
  <header class="gradient-header safe-top px-5 pt-6 pb-8 relative overflow-hidden">
    <!-- Decorative circles -->
    <div class="absolute -top-10 -right-10 w-40 h-40 rounded-full bg-white/5"></div>
    <div class="absolute -bottom-6 -left-6 w-28 h-28 rounded-full bg-white/5"></div>

    <div class="relative z-10">
      <div class="flex items-center justify-between mb-5">
        <div>
          <h1 class="text-white text-2xl font-bold tracking-tight">快工具箱</h1>
          <p class="text-blue-200 text-xs mt-0.5">20 款实用工具 · 一键直达</p>
        </div>
        <div class="w-11 h-11 rounded-2xl bg-white/15 flex items-center justify-center text-2xl backdrop-blur-sm">
          🧰
        </div>
      </div>

      <!-- Search Bar -->
      <div class="search-box bg-white/15 rounded-2xl flex items-center gap-2 px-4 py-2.5 backdrop-blur-sm transition-all">
        <svg class="w-4 h-4 text-blue-200 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
        </svg>
        <input
          id="searchInput"
          type="text"
          placeholder="搜索工具..."
          class="bg-transparent border-none outline-none text-white placeholder-blue-200/70 text-sm w-full"
        />
        <button id="clearSearch" class="text-blue-200 hover:text-white hidden">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <!-- ===== Category Tabs ===== -->
  <div class="sticky top-0 z-40 bg-white border-b border-gray-100 safe-top">
    <div class="flex overflow-x-auto no-scrollbar px-3 py-2.5 gap-2" id="catTabs">
      {categories.map(cat => (
        <button
          class={`cat-tab whitespace-nowrap px-4 py-1.5 rounded-full text-sm font-medium border ${
            cat.id === 'all'
              ? 'active bg-blue-600 text-white border-blue-600'
              : 'bg-gray-50 text-gray-600 border-gray-200'
          }`}
          data-cat={cat.id}
        >
          <span class="mr-1">{cat.emoji}</span>{cat.name}
        </button>
      ))}
    </div>
  </div>

  <!-- ===== Pull to refresh indicator ===== -->
  <div id="pullIndicator" class="pull-indicator">
    ↓ 下拉刷新
  </div>

  <!-- ===== Tool Cards ===== -->
  <main class="px-4 pt-4 pb-24" id="toolGrid">
    <!-- Section: all tools (rendered by JS for filter/search) -->
  </main>

  <!-- ===== Bottom Tab Bar ===== -->
  <nav class="fixed bottom-0 left-0 right-0 bg-white/95 backdrop-blur-lg border-t border-gray-200 safe-bottom z-50">
    <div class="flex justify-around py-1.5 max-w-lg mx-auto">
      <button class="tab-item active flex flex-col items-center py-1 px-4" data-tab="home">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9,22 9,12 15,12 15,22"/>
        </svg>
        <span class="text-[10px] mt-0.5 font-medium">首页</span>
        <span class="tab-dot w-1 h-1 rounded-full bg-blue-600 mt-0.5 opacity-0"></span>
      </button>
      <button class="tab-item flex flex-col items-center py-1 px-4 text-gray-400" data-tab="category">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
          <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
        </svg>
        <span class="text-[10px] mt-0.5">分类</span>
        <span class="tab-dot w-1 h-1 rounded-full bg-blue-600 mt-0.5 opacity-0"></span>
      </button>
      <button class="tab-item flex flex-col items-center py-1 px-4 text-gray-400" data-tab="about">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/>
        </svg>
        <span class="text-[10px] mt-0.5">关于</span>
        <span class="tab-dot w-1 h-1 rounded-full bg-blue-600 mt-0.5 opacity-0"></span>
      </button>
    </div>
  </nav>

  <!-- ===== About Modal ===== -->
  <div id="aboutModal" class="fixed inset-0 z-[60] hidden">
    <div class="absolute inset-0 bg-black/50" onclick="closeAbout()"></div>
    <div class="absolute bottom-0 left-0 right-0 bg-white rounded-t-3xl p-6 pb-10 safe-bottom max-h-[70vh] overflow-y-auto">
      <div class="flex justify-between items-start mb-4">
        <h2 class="text-lg font-bold">关于快工具箱</h2>
        <button onclick="closeAbout()" class="text-gray-400 hover:text-gray-600">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <div class="text-center mb-6">
        <div class="text-5xl mb-2">🧰</div>
        <h3 class="font-bold text-lg">快工具箱 v1.0</h3>
        <p class="text-gray-500 text-sm mt-1">20+ 款实用工具合集</p>
      </div>
      <div class="space-y-3 text-sm text-gray-600">
        <div class="flex justify-between py-2 border-b border-gray-100">
          <span>版本</span><span class="text-gray-900">1.0.0</span>
        </div>
        <div class="flex justify-between py-2 border-b border-gray-100">
          <span>工具数量</span><span class="text-gray-900">20 款</span>
        </div>
        <div class="flex justify-between py-2 border-b border-gray-100">
          <span>分类</span><span class="text-gray-900">6 大类</span>
        </div>
        <div class="flex justify-between py-2">
          <span>技术支持</span><span class="text-gray-900">AI + Cloudflare</span>
        </div>
      </div>
      <p class="text-xs text-gray-400 mt-6 text-center">
        快工具箱 · 让效率触手可及<br/>
        © 2026 hpennn. All rights reserved.
      </p>
    </div>
  </div>

  <script>
    // Tool data (mirrors server-side)
    const tools = [
      { name: '图片压缩', icon: '🗜️', url: 'https://www.kuaisutupo.xyz/', cat: 'image', desc: '无损压缩图片体积' },
      { name: '批量编辑', icon: '✂️', url: 'https://imgedit.hpennn.xyz/', cat: 'image', desc: '批量裁剪/旋转/水印' },
      { name: '尺寸修改', icon: '📐', url: 'https://imgsize.hpennn.xyz/', cat: 'image', desc: '调整图片尺寸像素' },
      { name: 'OCR识别', icon: '🔍', url: 'https://ocr.hpennn.xyz/', cat: 'image', desc: '图片文字识别导出' },
      { name: '文字工具', icon: '📝', url: 'https://www.hpenn.xyz/', cat: 'text', desc: '字数统计/格式转换' },
      { name: '文档转换', icon: '📄', url: 'https://convert.hpennn.xyz/', cat: 'doc', desc: 'PDF/Word/图片互转' },
      { name: '表格生成', icon: '📊', url: 'https://table.hpennn.xyz/', cat: 'doc', desc: '快速生成Excel表格' },
      { name: '文档总结', icon: '📋', url: 'https://doc.hpenn.xyz/', cat: 'doc', desc: 'AI一键提取要点' },
      { name: 'AI文案', icon: '✨', url: 'https://www.zhinenti.xyz/', cat: 'ai', desc: 'AI智能文案生成' },
      { name: 'AI智能命名', icon: '🏷️', url: 'https://www.hpenn.online/', cat: 'ai', desc: '取名/品牌/项目命名' },
      { name: 'AI祝福语', icon: '💝', url: 'https://www.zhinenti.vip/', cat: 'ai', desc: '节日祝福/生日贺词' },
      { name: 'AI简历', icon: '📑', url: 'https://resume.hpenn.xyz/', cat: 'ai', desc: '一键生成专业简历' },
      { name: 'AI PPT', icon: '📊', url: 'https://ppt.hpennn.xyz/', cat: 'ai', desc: 'AI生成演示文稿' },
      { name: '智能营销', icon: '📣', url: 'https://market.hpennn.xyz/', cat: 'ai', desc: 'AI营销文案生成' },
      { name: '内容工具', icon: '💡', url: 'https://content.hpennn.xyz/', cat: 'ai', desc: 'AI内容创作助手' },
      { name: 'AI客服', icon: '🤖', url: 'https://www.zhinenti.cn/', cat: 'ai', desc: 'AI智能对话客服' },
      { name: '开发工具', icon: '⚙️', url: 'https://www.hpennn.xyz/', cat: 'dev', desc: '开发者效率工具' },
      { name: '快工具', icon: '🚀', url: 'https://www.kuaisu.online/', cat: 'dev', desc: '实用在线小工具' },
      { name: 'AI导航', icon: '🧭', url: 'https://www.hpennn.online/', cat: 'dev', desc: 'AI工具资源导航' },
      { name: '发布助手', icon: '📤', url: 'https://publish.hpennn.xyz/', cat: 'market', desc: '多平台一键发布' },
    ];

    const catNames: Record<string, string> = {
      image: '🖼️ 图片处理',
      text: '✍️ 文字处理',
      doc: '📁 文档处理',
      ai: '🤖 AI 工具',
      dev: '💻 开发工具',
      market: '📢 推广营销',
    };

    const catColors: Record<string, string> = {
      image: 'bg-blue-50 text-blue-600',
      text: 'bg-green-50 text-green-600',
      doc: 'bg-purple-50 text-purple-600',
      ai: 'bg-orange-50 text-orange-600',
      dev: 'bg-slate-100 text-slate-600',
      market: 'bg-pink-50 text-pink-600',
    };

    let currentCat = 'all';
    let searchQuery = '';

    function renderTools() {
      const grid = document.getElementById('toolGrid')!;
      let filtered = tools;

      if (currentCat !== 'all') {
        filtered = filtered.filter(t => t.cat === currentCat);
      }
      if (searchQuery) {
        const q = searchQuery.toLowerCase();
        filtered = filtered.filter(t =>
          t.name.toLowerCase().includes(q) ||
          t.desc.toLowerCase().includes(q)
        );
      }

      if (filtered.length === 0) {
        grid.innerHTML = `
          <div class="flex flex-col items-center justify-center py-20 text-gray-400">
            <div class="text-5xl mb-3">🔍</div>
            <p class="text-sm">没有找到匹配的工具</p>
          </div>
        `;
        return;
      }

      // Group by category
      const grouped: Record<string, typeof tools> = {};
      for (const t of filtered) {
        if (!grouped[t.cat]) grouped[t.cat] = [];
        grouped[t.cat].push(t);
      }

      let html = '';
      for (const [cat, catTools] of Object.entries(grouped)) {
        html += `
          <div class="mb-5">
            <div class="flex items-center gap-2 mb-3 px-1">
              <span class="text-sm font-semibold text-gray-800">${catNames[cat] || cat}</span>
              <span class="text-xs text-gray-400">${catTools.length}款</span>
            </div>
            <div class="grid grid-cols-2 gap-3">
        `;
        for (const t of catTools) {
          const colorClass = catColors[t.cat] || 'bg-gray-50 text-gray-600';
          html += `
            <a href="${t.url}')"
               class="tool-card bg-white rounded-2xl p-4 shadow-sm border border-gray-100 flex flex-col gap-3 no-underline">
              <div class="flex items-start justify-between">
                <span class="text-3xl">${t.icon}</span>
                <span class="text-[10px] px-2 py-0.5 rounded-full ${colorClass} font-medium">${catNames[t.cat]?.split(' ')[1] || ''}</span>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 text-sm">${t.name}</h3>
                <p class="text-xs text-gray-400 mt-0.5 leading-relaxed">${t.desc}</p>
              </div>
              <div class="flex items-center gap-1 text-blue-500 text-xs font-medium mt-auto">
                <span>打开</span>
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path d="M9 18l6-6-6-6"/>
                </svg>
              </div>
            </a>
          `;
        }
        html += '</div></div>';
      }

      grid.innerHTML = html;
    }

    // Category tabs
    document.getElementById('catTabs')!.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('[data-cat]') as HTMLElement | null;
      if (!btn) return;
      currentCat = btn.dataset.cat!;

      // Update active state
      document.querySelectorAll('.cat-tab').forEach(tab => {
        const isActive = (tab as HTMLElement).dataset.cat === currentCat;
        tab.classList.toggle('active', isActive);
        if (isActive) {
          tab.className = 'cat-tab whitespace-nowrap px-4 py-1.5 rounded-full text-sm font-medium border active bg-blue-600 text-white border-blue-600';
        } else {
          tab.className = 'cat-tab whitespace-nowrap px-4 py-1.5 rounded-full text-sm font-medium border bg-gray-50 text-gray-600 border-gray-200';
        }
      });

      renderTools();
    });

    // Search
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const clearBtn = document.getElementById('clearSearch') as HTMLElement;

    searchInput.addEventListener('input', () => {
      searchQuery = searchInput.value.trim();
      clearBtn.classList.toggle('hidden', !searchQuery);
      renderTools();
    });

    clearBtn.addEventListener('click', () => {
      searchInput.value = '';
      searchQuery = '';
      clearBtn.classList.add('hidden');
      renderTools();
    });

    // Bottom tab bar
    document.querySelectorAll('.tab-item').forEach(tab => {
      tab.addEventListener('click', () => {
        const tabName = (tab as HTMLElement).dataset.tab;

        // Update active states
        document.querySelectorAll('.tab-item').forEach(t => {
          t.classList.remove('active');
          t.classList.add('text-gray-400');
        });
        tab.classList.add('active');
        tab.classList.remove('text-gray-400');

        if (tabName === 'about') {
          document.getElementById('aboutModal')!.classList.remove('hidden');
          // Reset tab to home
          setTimeout(() => {
            document.querySelectorAll('.tab-item').forEach(t => {
              t.classList.remove('active');
              t.classList.add('text-gray-400');
            });
            const homeTab = document.querySelector('[data-tab="home"]');
            homeTab?.classList.add('active');
            homeTab?.classList.remove('text-gray-400');
          }, 200);
        } else if (tabName === 'category') {
          // Scroll to categories
          document.getElementById('catTabs')!.scrollIntoView({ behavior: 'smooth' });
          setTimeout(() => {
            document.querySelectorAll('.tab-item').forEach(t => {
              t.classList.remove('active');
              t.classList.add('text-gray-400');
            });
            const homeTab = document.querySelector('[data-tab="home"]');
            homeTab?.classList.add('active');
            homeTab?.classList.remove('text-gray-400');
          }, 500);
        } else {
          // Home - scroll to top
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      });
    });

    // About modal
    (window as any).closeAbout = function() {
    };

    // Capacitor 外部链接处理
    (window as any).openTool = function(url: string) {
      if ((window as any).Capacitor) {
        // 在 Capacitor 中用系统浏览器打开
        (window as any).Capacitor.Platform.openUrl(url);
      } else {
        window.open(url, "_blank", "noopener");
      }
      document.getElementById('aboutModal')!.classList.add('hidden');
    };

    // Pull to refresh
    let touchStartY = 0;
    const pullIndicator = document.getElementById('pullIndicator')!;

    document.addEventListener('touchstart', (e) => {
      if (window.scrollY === 0) {
        touchStartY = e.touches[0].clientY;
      }
    }, { passive: true });

    document.addEventListener('touchmove', (e) => {
      if (touchStartY > 0 && window.scrollY === 0) {
        const diff = e.touches[0].clientY - touchStartY;
        if (diff > 50) {
          pullIndicator.classList.add('show');
        }
      }
    }, { passive: true });

    document.addEventListener('touchend', () => {
      if (pullIndicator.classList.contains('show')) {
        pullIndicator.classList.remove('show');
        renderTools(); // Refresh
      }
      touchStartY = 0;
    });


    // ===== Capacitor 原生App: 外部链接用系统浏览器打开 =====
    if ((window as any).Capacitor?.isNativePlatform?.()) {
      document.addEventListener('click', (e) => {
        const anchor = (e.target as HTMLElement).closest('a');
        if (!anchor) return;
        const href = anchor.getAttribute('href');
        if (href && (href.startsWith('http://') || href.startsWith('https://')) && !href.includes(window.location.hostname)) {
          e.preventDefault();
          // 系统浏览器打开外部链接
          window.open(href, '_blank');
        }
      });
    }

    // Initial render
    renderTools();
  </script>
</Base>
