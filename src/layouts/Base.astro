---
interface Props {
  title?: string;
}
const { title = '快工具箱' } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="theme-color" content="#1e40af" />
  <meta name="description" content="快工具箱 - 20+款实用工具合集，图片处理、文字处理、文档转换、AI工具一站式移动端工具箱" />
  <link rel="manifest" href="/manifest.json" />
  <link rel="apple-touch-icon" href="/icons/icon-192.png" />
  <link rel="icon" type="image/svg+xml" href="/icons/icon.svg" />
  <title>{title}</title>
  <style>
    /* Safe area support */
    .safe-top { padding-top: env(safe-area-inset-top); }
    .safe-bottom { padding-bottom: env(safe-area-inset-bottom); }
    /* Hide scrollbar */
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    /* Card press effect */
    .card-press { transition: transform 0.15s, box-shadow 0.15s; }
    .card-press:active { transform: scale(0.97); }
    /* Search expand */
    .search-box:focus-within { box-shadow: 0 0 0 3px rgba(59,130,246,0.3); }
    /* Category tab indicator */
    .cat-tab { transition: all 0.2s; }
    .cat-tab.active { background: #2563eb; color: white; }
    /* Tool card */
    .tool-card { transition: transform 0.15s ease, box-shadow 0.15s ease; }
    .tool-card:active { transform: scale(0.96); }
    /* Tab bar */
    .tab-item { transition: color 0.2s; }
    .tab-item.active { color: #2563eb; }
    .tab-item.active .tab-dot { opacity: 1; }
    /* Gradient bg */
    .gradient-header {
      background: linear-gradient(135deg, #1e40af 0%, #3b82f6 50%, #6366f1 100%);
    }
    /* Splash */
    .splash {
      position: fixed; inset: 0; z-index: 9999;
      background: linear-gradient(135deg, #1e40af 0%, #6366f1 100%);
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      transition: opacity 0.4s ease;
    }
    .splash.hide { opacity: 0; pointer-events: none; }
    /* Pull refresh */
    .pull-indicator {
      transition: transform 0.3s;
      text-align: center;
      color: #94a3b8;
      font-size: 0.8rem;
      overflow: hidden;
      max-height: 0;
    }
    .pull-indicator.show { max-height: 50px; padding: 8px 0; }
  </style>
</head>
<body class="bg-gray-50 min-h-screen font-sans antialiased">
  <!-- Splash Screen -->
  <div id="splash" class="splash">
    <div class="text-6xl mb-4">🧰</div>
    <h1 class="text-white text-2xl font-bold">快工具箱</h1>
    <p class="text-blue-200 text-sm mt-2">加载中...</p>
  </div>

  <slot />

  <script>
    // Hide splash after load
    window.addEventListener('load', () => {
      setTimeout(() => {
        const splash = document.getElementById('splash');
        if (splash) {
          splash.classList.add('hide');
          setTimeout(() => splash.remove(), 400);
        }
      }, 300);
    });

    // Register Service Worker
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js').catch(() => {});
    }
  </script>
  <!-- Auto-update detection for Capacitor App -->
  <script is:inline>
  (function(){
    if(typeof window.Capacitor==='undefined')return;
    var REPO=toolbox-app';
    var VER=1.0.0';
    function check(){
      fetch('https://api.github.com/repos/hpennn/'+REPO+'/releases/latest')
      .then(function(r){return r.json()})
      .then(function(d){
        var lv=(d.tag_name||'').replace(/^v/,'');
        if(cmpVer(lv,VER)>0)showDlg(lv,d);
      }).catch(function(){});
    }
    function cmpVer(a,b){
      var pa=a.split('.').map(Number),pb=b.split('.').map(Number);
      for(var i=0;i<Math.max(pa.length,pb.length);i++){
        if((pa[i]||0)>(pb[i]||0))return 1;
        if((pa[i]||0)<(pb[i]||0))return -1;
      }return 0;
    }
    function showDlg(ver,data){
      var apk=(data.assets||[]).find(function(a){return a.name.endsWith('.apk')});
      var url=apk?apk.browser_download_url:data.html_url;
      var o=document.createElement('div');
      o.style.cssText='position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:99999;display:flex;align-items:center;justify-content:center';
      o.innerHTML='<div style="background:#fff;border-radius:16px;padding:24px;margin:20px;max-width:300px;text-align:center">'
        +'<div style="width:48px;height:48px;background:linear-gradient(135deg,#3b82f6,#8b5cf6);border-radius:12px;margin:0 auto 16px;display:flex;align-items:center;justify-content:center"><svg width="24" height="24" fill="none" stroke="#fff" stroke-width="2" viewBox="0 0 24 24"><path d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg></div>'
        +'<h3 style="margin:0 0 8px;font-size:18px;color:#111">发现新版本</h3>'
        +'<p style="margin:0 0 4px;font-size:14px;color:#666">v'+VER+' → v'+ver+'</p>'
        +'<p style="margin:0 0 20px;font-size:13px;color:#999">更新包含Bug修复和性能优化</p>'
        +'<a href="'+url+'" style="display:block;background:linear-gradient(135deg,#3b82f6,#2563eb);color:#fff;text-decoration:none;padding:12px;border-radius:10px;font-size:15px;font-weight:600;margin-bottom:10px">立即下载更新</a>'
        +'<button onclick="this.parentElement.parentElement.remove()" style="background:0 0;border:0;color:#999;font-size:13px;cursor:pointer;padding:8px;width:100%">稍后再说</button>'
        +'</div>';
      o.addEventListener('click',function(e){if(e.target===o)o.remove()});
      document.body.appendChild(o);
    }
    document.readyState==='complete'?setTimeout(check,2e3):window.addEventListener('load',function(){setTimeout(check,2e3)});
  })();
  </script>
</body>
</html>
